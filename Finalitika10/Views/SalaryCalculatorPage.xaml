<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels.PlanViewModels"
             xmlns:models="clr-namespace:Finalitika10.Models"
             xmlns:controls="clr-namespace:Finalitika10.Views.JobForms"
             x:DataType="viewmodels:SalaryCalculatorViewModel"
             x:Class="Finalitika10.Views.SalaryCalculatorPage"
             Title="SalaryCalculatorPage">
    <Border BackgroundColor="White" VerticalOptions="End" Padding="20,20,20,40" Margin="0,50,0,0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24,24,0,0" />
        </Border.StrokeShape>

        <ScrollView>
            <VerticalStackLayout Spacing="20">

                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Калькулятор дохода" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50"/>
                        <Label Text="Проверьте данные на текущий месяц" FontSize="12" TextColor="#7F8C8D"/>
                    </VerticalStackLayout>
                    <ImageButton Grid.Column="1" Source="close_icon.png" Command="{Binding CloseCommand}" WidthRequest="44" HeightRequest="44" Padding="10" BackgroundColor="Transparent"/>
                </Grid>

                <controls:JobParametersForm />

                <Button Text="Построить график и рассчитать" 
                        Command="{Binding CalculateCommand}" 
                        BackgroundColor="#3498DB" 
                        TextColor="White" 
                        CornerRadius="12" 
                        HeightRequest="50" 
                        FontAttributes="Bold"/>

                <VerticalStackLayout Spacing="15" IsVisible="{Binding IsCalculated}">
                    <BoxView HeightRequest="1" Color="#E0E0E0"/>

                    <Label Text="Календарь рабочих смен:" FontAttributes="Bold" TextColor="#2C3E50"/>

                    <CollectionView ItemsSource="{Binding CalendarDays}" HeightRequest="200">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="7" VerticalItemSpacing="5" HorizontalItemSpacing="5"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ShiftDay">
                                <Border BackgroundColor="{Binding BackgroundColor}" Stroke="Transparent" HeightRequest="40" Padding="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding DayNumber}" TextColor="{Binding TextColor}" FontAttributes="{Binding FontAttribute}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="5" Margin="0,10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Рабочих смен:" TextColor="#7F8C8D" VerticalOptions="Center"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalWorkDays}" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="Аванс:" TextColor="#7F8C8D" IsVisible="{Binding Job.HasAdvance}" VerticalOptions="Center"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding AdvanceAmount, StringFormat='{0:N0} ₽'}" FontAttributes="Bold" TextColor="#2C3E50" IsVisible="{Binding Job.HasAdvance}" VerticalOptions="Center"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Итого на руки:" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding FinalIncome, StringFormat='{0:N0} ₽'}" FontSize="18" FontAttributes="Bold" TextColor="#27AE60" VerticalOptions="Center"/>
                    </Grid>

                    <Button Text="Применить к плану доходов" 
                            Command="{Binding ApplyAndCloseCommand}" 
                            BackgroundColor="#27AE60" 
                            TextColor="White" 
                            CornerRadius="12" 
                            HeightRequest="50" 
                            FontAttributes="Bold"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Border>
</ContentPage>