<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Finalitika10.Models"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels.PlanViewModels"
             x:DataType="viewmodels:PlansViewModel"
             x:Class="Finalitika10.PlansPage" BackgroundColor="White">
    <Grid>

        <ScrollView>
            <VerticalStackLayout Spacing="25" Padding="0,20,0,40">

                <VerticalStackLayout Spacing="15" Padding="20,0">
                    <Label Text="Сценарии жизни 🔮" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50"/>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Scenarios}" Spacing="15">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:LifeScenario">
                                <Border Stroke="Transparent" BackgroundColor="White" Padding="20">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Opacity="0.05" Offset="0,4" Radius="8"/>
                                    </Border.Shadow>
                                    <VerticalStackLayout Spacing="10">
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="{Binding Icon}" FontSize="24" VerticalOptions="Center"/>
                                            <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Description}" FontSize="14" TextColor="#7F8C8D" LineBreakMode="WordWrap"/>
                                        <Button Text="{Binding ActionText}" BackgroundColor="{Binding ActionColor}" TextColor="White" CornerRadius="8" HeightRequest="40" Margin="0,10,0,0"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*, Auto" Padding="20,0" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Мои проекты" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Все >" FontSize="14" TextColor="#3498DB" VerticalOptions="Center" Padding="10">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ViewAllProjectsCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Always" Padding="20,0,20,10">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Projects}" Spacing="15">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:FinancialProject">
                                    <Border Stroke="Transparent" BackgroundColor="{Binding BackgroundColor}" WidthRequest="220" HeightRequest="160" Padding="15">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PlansViewModel}}, Path=OpenProjectCommand}" CommandParameter="{Binding}"/>
                                        </Border.GestureRecognizers>

                                        <Grid RowDefinitions="Auto, *, Auto, Auto">
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *">
                                                <Label Grid.Column="0" Text="{Binding Emoji}" FontSize="24"/>
                                                <Border Grid.Column="1" BackgroundColor="White" Opacity="0.8" Padding="8,2" Stroke="Transparent" HorizontalOptions="End" IsVisible="{Binding HasMultipleParticipants}">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="10" />
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding ParticipantsCount, StringFormat='👥 {0}'}" FontSize="12" FontAttributes="Bold" TextColor="#2C3E50"/>
                                                </Border>
                                            </Grid>

                                            <Label Grid.Row="1" Text="{Binding Title}" FontSize="18" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                                            <ProgressBar Grid.Row="2" Progress="{Binding Progress}" ProgressColor="White" BackgroundColor="#80FFFFFF" HeightRequest="6" Margin="0,0,0,8"/>

                                            <Grid Grid.Row="3" ColumnDefinitions="Auto, *">
                                                <Label Grid.Column="0" Text="{Binding CollectedAmount, StringFormat='{0:N0} ₽'}" FontSize="12" FontAttributes="Bold" TextColor="White"/>
                                                <Label Grid.Column="1" Text="{Binding TargetAmount, StringFormat='из {0:N0}'}" FontSize="12" TextColor="#D5DBDB" HorizontalOptions="End"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" Padding="20,0">
                    <Label Text="Бюджет на месяц" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50"/>
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="20">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Ожидаемый доход:" FontSize="14" TextColor="#7F8C8D" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding PlannedIncome, StringFormat='{0:N0} ₽'}" FontSize="18" FontAttributes="Bold" TextColor="#27AE60" VerticalOptions="Center"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#EEEEEE"/>

                            <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="🛒 Постоянные нужды:" FontSize="14" TextColor="#34495E"/>
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding AllocatedNeeds, StringFormat='{0:N0} ₽'}" FontSize="14" FontAttributes="Bold"/>

                                <Label Grid.Row="1" Grid.Column="0" Text="📈 В проекты/инвестиции:" FontSize="14" TextColor="#34495E"/>
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding AllocatedSavings, StringFormat='{0:N0} ₽'}" FontSize="14" FontAttributes="Bold" TextColor="#3498DB"/>

                                <Label Grid.Row="2" Grid.Column="0" Text="🤔 Свободно:" FontSize="14" TextColor="#34495E"/>
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding Unallocated, StringFormat='{0:N0} ₽'}" FontSize="14" FontAttributes="Bold" TextColor="#F39C12"/>
                            </Grid>

                            <Button Text="Калькулятор ЗП по графику" Command="{Binding CalculateSalaryCommand}" BackgroundColor="#F4F6F8" TextColor="#3498DB" CornerRadius="8" HeightRequest="40" Margin="0,10,0,0"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" Padding="20,0">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Предстоящие платежи" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Все >" FontSize="14" TextColor="#3498DB" VerticalOptions="Center" Padding="10">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ViewAllPaymentsCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Payments}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:PaymentReminder">
                                <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="15">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Border Grid.Column="0" BackgroundColor="#F4F6F8" WidthRequest="40" HeightRequest="40" Stroke="Transparent" Margin="0,0,15,0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Icon}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                                            <Label Text="{Binding DisplayDate}" FontSize="12" TextColor="#7F8C8D"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="2">
                                            <Label Text="{Binding Amount, StringFormat='-{0:N0} ₽'}" FontAttributes="Bold" TextColor="#E74C3C" HorizontalOptions="End"/>
                                            <Label Text="🔔 Вкл" FontSize="10" TextColor="#27AE60" HorizontalOptions="End" IsVisible="{Binding IsPushEnabled}"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" Padding="20,0">
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Заметки проектов" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Все >" FontSize="14" TextColor="#3498DB" VerticalOptions="Center" Padding="10">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ViewAllNotesCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <FlexLayout BindableLayout.ItemsSource="{Binding Notes}" Wrap="Wrap" JustifyContent="SpaceBetween">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:ProjectNote">
                                <Border Stroke="Transparent" BackgroundColor="{Binding ColorHex}" WidthRequest="165" Padding="15" Margin="0,0,0,15">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PlansViewModel}}, Path=OpenNoteCommand}" CommandParameter="{Binding}"/>
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14" TextColor="#2C3E50" MaxLines="2" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding PreviewText}" FontSize="12" TextColor="#34495E" MaxLines="4" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Date}" FontSize="10" TextColor="#7F8C8D" Margin="0,10,0,0"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView BackgroundColor="Black" Opacity="0.6" IsVisible="{Binding IsFabMenuOpen}">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFabMenuCommand}"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <VerticalStackLayout HorizontalOptions="End" VerticalOptions="End" Margin="20" Spacing="15">
            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Платеж" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="💳" Command="{Binding AddPaymentCommand}" BackgroundColor="White" TextColor="#2C3E50" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Проект" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="🎯" Command="{Binding AddProjectCommand}" BackgroundColor="White" TextColor="#2C3E50" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Заметка" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="📝" Command="{Binding AddNoteCommand}" BackgroundColor="White" TextColor="#2C3E50" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <Button Text="{Binding FabIcon}" Command="{Binding ToggleFabMenuCommand}" FontAttributes="Bold" FontSize="28" TextColor="White" BackgroundColor="#6750A4" CornerRadius="28" HeightRequest="56" WidthRequest="56" HorizontalOptions="End" Margin="0,5,0,0">
                <Button.Shadow>
                    <Shadow Brush="Black" Opacity="0.3" Offset="0,4" Radius="8"/>
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>
    </Grid>
</ContentPage>