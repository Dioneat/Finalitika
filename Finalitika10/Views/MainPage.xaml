<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Finalitika10.Models"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels"
             x:DataType="viewmodels:MainViewModel"
             x:Class="Finalitika10.MainPage" BackgroundColor="White">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="25" Padding="0,20,0,100">

                <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,0" VerticalOptions="Center">
                    <ImageButton Grid.Column="0" Source="chevron_left.png" Command="{Binding PreviousMonthCommand}" WidthRequest="12" HeightRequest="12"/>
                    <Label Grid.Column="1" Text="{Binding CurrentPeriod}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <ImageButton Grid.Column="2" Source="chevron_right.png" Command="{Binding NextMonthCommand}" WidthRequest="12" HeightRequest="12"/>
                </Grid>

                <Border BackgroundColor="#6750A4" Padding="25" WidthRequest="200" HeightRequest="200" HorizontalOptions="Center" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="100"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="Остаток на месяц" FontSize="15" TextColor="#E6E0F8" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="{Binding BalanceText}" FontSize="28" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10" Padding="20,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleDailyBudgetCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Бюджет дня" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                        <Label Grid.Column="1" Text="👁️" FontSize="16" Opacity="0.5"/>
                    </Grid>
                    <Border BackgroundColor="White" Padding="20" Stroke="Transparent" IsVisible="{Binding IsDailyBudgetVisible}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="Доступно сегодня" FontSize="12" TextColor="#7F8C8D"/>
                                    <Label Text="{Binding DailyBudgetLimit, StringFormat='{0:N0} ₽'}" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                                    <Label Text="Потрачено" FontSize="12" TextColor="#7F8C8D" HorizontalOptions="End"/>
                                    <Label Text="{Binding DailyBudgetSpent, StringFormat='{0:N0} ₽'}" FontSize="20" FontAttributes="Bold" TextColor="{Binding DailyBudgetColor}" HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Grid>
                            <ProgressBar Progress="{Binding DailyBudgetProgress}" ProgressColor="{Binding DailyBudgetColor}" HeightRequest="8"/>
                            <Label Text="{Binding DailyBudgetMessage}" FontSize="12" TextColor="{Binding DailyBudgetColor}" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto" Padding="20,0">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleAccountsCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Мои счета" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                        <Label Grid.Column="1" Text="👁️" FontSize="16" Opacity="0.5"/>
                    </Grid>
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" IsVisible="{Binding IsAccountsVisible}">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding ActiveAccounts}" Spacing="15" Padding="20,5,20,15">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:BankAccount">
                                    <Border BackgroundColor="White" WidthRequest="140" Padding="15" Stroke="Transparent">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                                        </Border.Shadow>
                                        <VerticalStackLayout Spacing="10">
                                            <Border BackgroundColor="{Binding ColorHex, StringFormat='{0}1A'}" WidthRequest="40" HeightRequest="40" Stroke="Transparent" HorizontalOptions="Start">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Icon}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" MaxLines="1"/>
                                            <Label Text="{Binding Balance, StringFormat='{0:N0} ₽'}" FontSize="14" TextColor="#7F8C8D"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" Padding="0,10,0,0">
                    <Grid ColumnDefinitions="*, Auto" Padding="20,0">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePaymentCalendarCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Календарь платежей" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                        <Label Grid.Column="1" Text="👁️" FontSize="16" Opacity="0.5"/>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsPaymentCalendarVisible}" Spacing="15" Padding="20,5,20,20">

                        <Border BackgroundColor="#FDEDEC" Stroke="#E74C3C" StrokeThickness="1" Padding="15" IsVisible="{Binding HasCashGapWarning}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *">
                                <Label Grid.Column="0" Text="⚠️" FontSize="20" VerticalOptions="Center" Margin="0,0,10,0"/>
                                <Label Grid.Column="1" Text="{Binding CashGapMessage}" FontSize="13" TextColor="#C0392B" FontAttributes="Bold" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding UpcomingPayments}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:PaymentEvent">
                                    <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05"/>
                                        </Border.Shadow>

                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="45">
                                                <Border BackgroundColor="{Binding IconBackgroundColor, StringFormat='{0}26'}" WidthRequest="36" HeightRequest="36" Stroke="Transparent" HorizontalOptions="Center">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="18"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding Icon}" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="{Binding DisplayDate}" FontSize="10" FontAttributes="Bold" TextColor="#7F8C8D" HorizontalOptions="Center" Margin="0,4,0,0"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" TextColor="#2C3E50" MaxLines="1"/>
                                                <Label Text="{Binding Subtitle}" FontSize="12" TextColor="#95A5A6" MaxLines="1"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="5">
                                                <Label Text="{Binding Amount, StringFormat='{0:N0} ₽'}" TextColor="{Binding AmountColor}" FontSize="15" FontAttributes="Bold" HorizontalOptions="End"/>

                                                <HorizontalStackLayout HorizontalOptions="End" Spacing="5" IsVisible="{Binding IsExpense}">
                                                    <Label Text="Авто" FontSize="10" TextColor="#BDC3C7" VerticalOptions="Center"/>
                                                    <Switch IsToggled="{Binding IsAutoPaymentEnabled}" Scale="0.7" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto" Padding="20,0">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleGoalsCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Мои цели" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                        <Label Grid.Column="1" Text="👁️" FontSize="16" Opacity="0.5"/>
                    </Grid>

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" IsVisible="{Binding IsGoalsVisible}">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding ActiveGoals}" Spacing="15" Padding="20,5,20,20">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:FinancialGoal">
                                    <Border BackgroundColor="White" WidthRequest="220" Padding="15" Stroke="Transparent">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                                        </Border.Shadow>

                                        <VerticalStackLayout Spacing="12">
                                            <Grid ColumnDefinitions="Auto, *">
                                                <Border Grid.Column="0" BackgroundColor="#F4F6F8" WidthRequest="40" HeightRequest="40" Stroke="Transparent">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="10"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding Icon}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>

                                                <Border Grid.Column="1" BackgroundColor="{Binding ProgressBarColor, StringFormat='{0}1A'}" HorizontalOptions="End" VerticalOptions="Center" Padding="8,4" Stroke="Transparent">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding ProgressPercentText}" FontSize="12" FontAttributes="Bold" TextColor="{Binding ProgressBarColor}"/>
                                                </Border>
                                            </Grid>

                                            <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" TextColor="#2C3E50" MaxLines="1" LineBreakMode="TailTruncation"/>
                                            <ProgressBar Progress="{Binding Progress}" ProgressColor="{Binding ProgressBarColor}" HeightRequest="6" />

                                            <Grid ColumnDefinitions="*, Auto">
                                                <VerticalStackLayout Grid.Column="0">
                                                    <Label Text="Собрано" FontSize="10" TextColor="#BDC3C7"/>
                                                    <Label Text="{Binding CurrentAmount, StringFormat='{0:N0} ₽'}" FontSize="13" FontAttributes="Bold" TextColor="#2C3E50"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                                                    <Label Text="Цель" FontSize="10" TextColor="#BDC3C7" HorizontalOptions="End"/>
                                                    <Label Text="{Binding TargetAmount, StringFormat='{0:N0} ₽'}" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" HorizontalOptions="End"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" Padding="20,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleWeeklyReportCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="Итоги недели" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                        <Label Grid.Column="1" Text="👁️" FontSize="16" Opacity="0.5"/>
                    </Grid>

                    <Border BackgroundColor="White" Padding="20" Stroke="Transparent" IsVisible="{Binding IsWeeklyReportVisible}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05"/>
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, *">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Заработано" FontSize="12" TextColor="#7F8C8D"/>
                                    <Label Text="{Binding WeeklyEarned, StringFormat='+{0:N0} ₽'}" FontSize="18" FontAttributes="Bold" TextColor="#27AE60"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End">
                                    <Label Text="Потрачено" FontSize="12" TextColor="#7F8C8D" HorizontalOptions="End"/>
                                    <Label Text="{Binding WeeklySpent, StringFormat='-{0:N0} ₽'}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F4F6F8" Margin="0,5"/>

                            <Grid ColumnDefinitions="*, Auto" VerticalOptions="End">
                                <VerticalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center" Margin="0,0,15,0">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0" Text="Лимит на неделю" FontSize="12" TextColor="#7F8C8D"/>
                                        <Label Grid.Column="1" Text="{Binding WeeklyBudgetLimit, StringFormat='{0:N0} ₽'}" FontSize="12" FontAttributes="Bold" TextColor="#2C3E50"/>
                                    </Grid>
                                    <ProgressBar Progress="{Binding WeeklyBudgetProgress}" ProgressColor="{Binding WeeklyBudgetColor}" HeightRequest="6"/>
                                </VerticalStackLayout>

                                <Border Grid.Column="1" BackgroundColor="{Binding WeeklyBudgetColor, StringFormat='{0}1A'}" Padding="8,4" Stroke="Transparent" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding WeeklyPercentageText, StringFormat='Расход: {0}'}" FontSize="11" FontAttributes="Bold" TextColor="{Binding WeeklyBudgetColor}"/>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <BoxView Color="#80000000" IsVisible="{Binding IsFabMenuOpen}" InputTransparent="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFabMenuCommand}"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <VerticalStackLayout VerticalOptions="End" HorizontalOptions="End" Margin="20,20,20,30" Spacing="15">
            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Доход" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="+" Command="{Binding AddTransactionCommand}" CommandParameter="Доход" BackgroundColor="#27AE60" TextColor="White" FontSize="24" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Расход" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="−" Command="{Binding AddTransactionCommand}" CommandParameter="Расход" BackgroundColor="#E74C3C" TextColor="White" FontSize="24" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Перевод" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="⇄" Command="{Binding AddTransferCommand}" BackgroundColor="#3498DB" TextColor="White" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <Button Text="{Binding FabIcon}" Command="{Binding ToggleFabMenuCommand}" BackgroundColor="#6750A4" TextColor="White" FontSize="28" CornerRadius="28" HeightRequest="56" WidthRequest="56" HorizontalOptions="End" Margin="0,5,0,0">
                <Button.Shadow>
                    <Shadow Brush="Black" Opacity="0.3" Offset="0,4" Radius="8"/>
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>
    </Grid>
</ContentPage>