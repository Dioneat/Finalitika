<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Finalitika10.Views.AddTransactionPage"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels.AnalysisViewModels"
             x:DataType="viewmodels:AddTransactionViewModel"
             Title="AddTransactionPage">

    <Border BackgroundColor="White" VerticalOptions="End" Padding="20,20,20,40" Margin="0,50,0,0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24,24,0,0" />
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="20">
            <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <Label Grid.Column="0" Text="{Binding PageTitle}" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                <ImageButton Grid.Column="1" Source="close_icon.png" Command="{Binding CloseCommand}" WidthRequest="44" HeightRequest="44" Padding="10" BackgroundColor="Transparent"/>
            </Grid>

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="Сумма (₽)" FontSize="12" TextColor="#7F8C8D" HorizontalOptions="Center"/>
                <Entry Text="{Binding Amount}" Keyboard="Numeric" FontSize="36" FontAttributes="Bold" TextColor="{Binding AmountColor}" HorizontalTextAlignment="Center" BackgroundColor="Transparent" WidthRequest="200"/>
                <BoxView HeightRequest="2" Color="{Binding AmountColor}" WidthRequest="150" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Счет списания/зачисления:" FontSize="12" TextColor="#7F8C8D"/>
                    <Picker Title="Выберите счет" ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" ItemDisplayBinding="{Binding Name}" BackgroundColor="#F4F6F8" TextColor="#2C3E50"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Категория:" FontSize="12" TextColor="#7F8C8D"/>
                    <Picker Title="Выберите категорию" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" ItemDisplayBinding="{Binding Name}" BackgroundColor="#F4F6F8" TextColor="#2C3E50"/>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Дата:" FontSize="12" TextColor="#7F8C8D"/>
                        <DatePicker Date="{Binding Date}" BackgroundColor="#F4F6F8" TextColor="#2C3E50"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Комментарий:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding Comment}" Placeholder="Например, такси" BackgroundColor="#F4F6F8"/>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>

            <Button Text="Добавить операцию" Command="{Binding SaveCommand}" BackgroundColor="{Binding AmountColor}" TextColor="White" CornerRadius="12" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0"/>
        </VerticalStackLayout>
    </Border>
</ContentPage>