<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:DataType="viewmodels:ProfileViewModel"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels"
             x:Class="Finalitika10.ProfilePage" 
             BackgroundColor="#F4F6F8">
    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="20">

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,10,0,10">
                <Border WidthRequest="100" HeightRequest="100" Padding="0" BackgroundColor="#E3F2FD" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="50" />
                    </Border.StrokeShape>
                    <Label Text="{Binding UserInitials}" 
                                FontSize="36" 
                                FontAttributes="Bold" 
                                TextColor="#3498DB" 
                                HorizontalOptions="Center" 
                                VerticalOptions="Center"/>
                </Border>
                <Label Text="{Binding UserName}" FontSize="24" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Border BackgroundColor="White" Padding="15" Stroke="Transparent" Margin="0,5,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding EditJobCommand}"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                    <Border Grid.Column="0" BackgroundColor="#FCE4EC" WidthRequest="50" HeightRequest="50" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="💼" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding UserJob.PositionName}" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding UserJob.ScheduleType, StringFormat='График: {0}'}" FontSize="13" TextColor="#7F8C8D"/>
                            <Label Text="•" FontSize="13" TextColor="#BDC3C7"/>
                            <Label Text="{Binding UserJob.Rate, StringFormat='{0:N0} ₽'}" FontSize="13" FontAttributes="Bold" TextColor="#27AE60"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Label Grid.Column="2" Text="✏️" FontSize="18" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="15">

                <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToPersonalDataCommand}"/>
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Border Grid.Column="0" BackgroundColor="#E8EAF6" WidthRequest="45" HeightRequest="45" Stroke="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label Text="🪪" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Личные данные" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                            <Label Text="Паспорт, ИНН, Телефон" FontSize="12" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToDocumentsCommand}"/>
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Border Grid.Column="0" BackgroundColor="#E8F8F5" WidthRequest="45" HeightRequest="45" Stroke="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label Text="📄" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Шаблоны документов" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                            <Label Text="Генерация договоров и заявлений" FontSize="12" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToCurrenciesCommand}"/>
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Border Grid.Column="0" BackgroundColor="#EBF5FB" WidthRequest="45" HeightRequest="45" Stroke="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label Text="💱" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Курсы валют" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                            <Label Text="Отслеживание курсов ЦБ РФ" FontSize="12" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToSettingsCommand}"/>
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Border Grid.Column="0" BackgroundColor="#FFF9C4" WidthRequest="45" HeightRequest="45" Stroke="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label Text="⚙️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Настройки" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                            <Label Text="Безопасность и интеграции" FontSize="12" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <Button Text="Выйти из аккаунта" 
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent" 
                    TextColor="#E74C3C" 
                    FontAttributes="Bold"
                    BorderWidth="1"
                    BorderColor="#E74C3C"
                    CornerRadius="12"
                    HeightRequest="50"
                    Margin="0, 20, 0, 0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>