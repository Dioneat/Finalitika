<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:DataType="viewmodels:ProfileViewModel"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels"
             x:Class="Finalitika10.ProfilePage" BackgroundColor="#F6F6F6">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="20">

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,10,0,10">
                <Frame WidthRequest="100" HeightRequest="100" CornerRadius="50" Padding="0" IsClippedToBounds="True" BackgroundColor="#E3F2FD" HasShadow="False">
                    <Label Text="ИИ" FontSize="36" FontAttributes="Bold" TextColor="#3498DB" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>

                <Label Text="{Binding UserName}" FontSize="24" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center"/>
                <Label Text="{Binding UserEmail}" FontSize="14" TextColor="#7F8C8D" HorizontalOptions="Center"/>

                <Frame BackgroundColor="#FFF3E0" CornerRadius="8" Padding="10,5" HasShadow="False" HorizontalOptions="Center" Margin="0,5,0,0">
                    <Label Text="{Binding InvestorLevel}" TextColor="#EF6C00" FontSize="12" FontAttributes="Bold"/>
                </Frame>
            </VerticalStackLayout>
            <Border BackgroundColor="White" Padding="15" Stroke="Transparent" Margin="0,5,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding EditJobCommand}"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                    <Border Grid.Column="0" BackgroundColor="#FCE4EC" WidthRequest="50" HeightRequest="50" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="💼" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding UserJob.PositionName}" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding UserJob.ScheduleType, StringFormat='График: {0}'}" FontSize="13" TextColor="#7F8C8D"/>
                            <Label Text="•" FontSize="13" TextColor="#BDC3C7"/>
                            <Label Text="{Binding UserJob.Rate, StringFormat='{0:N0} ₽'}" FontSize="13" FontAttributes="Bold" TextColor="#27AE60"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Label Grid.Column="2" Text="✏️" FontSize="18" VerticalOptions="Center"/>
                </Grid>
            </Border>
            <VerticalStackLayout Spacing="15">

                <Frame BackgroundColor="White" CornerRadius="16" Padding="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToDocumentsCommand}"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Frame Grid.Column="0" BackgroundColor="#E8F6F3" CornerRadius="12" WidthRequest="45" HeightRequest="45" Padding="0" HasShadow="False">
                            <Label Text="📄" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Мои документы" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                            <Label Text="Генерация договоров и заявлений" FontSize="12" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <Frame BackgroundColor="White" CornerRadius="16" Padding="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToCurrenciesCommand}"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Frame Grid.Column="0" BackgroundColor="#EBF5FB" CornerRadius="12" WidthRequest="45" HeightRequest="45" Padding="0" HasShadow="False">
                            <Label Text="💱" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Курсы валют" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                            <Label Text="Отслеживание курсов ЦБ РФ" FontSize="12" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <Frame BackgroundColor="White" CornerRadius="16" Padding="15" HasShadow="True" BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToSettingsCommand}"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Frame Grid.Column="0" BackgroundColor="#F9E79F" CornerRadius="12" WidthRequest="45" HeightRequest="45" Padding="0" HasShadow="False">
                            <Label Text="⚙️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Настройки API" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                            <Label Text="Tinkoff API Токен и безопасность" FontSize="12" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </Frame>

            </VerticalStackLayout>

            <Button Text="Выйти из аккаунта" 
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent" 
                    TextColor="#E74C3C" 
                    FontAttributes="Bold"
                    BorderWidth="1"
                    BorderColor="#E74C3C"
                    CornerRadius="12"
                    HeightRequest="50"
                    Margin="0, 20, 0, 0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>