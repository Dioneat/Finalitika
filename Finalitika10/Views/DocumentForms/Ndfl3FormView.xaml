<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels"
             x:DataType="viewmodels:DocumentEditorViewModel"
             x:Class="Finalitika10.Views.DocumentForms.Ndfl3FormView">

    <ContentView.Resources>
        <Style TargetType="Entry">
            <Setter Property="BackgroundColor" Value="#F8F9FA"/>
            <Setter Property="TextColor" Value="#2C3E50"/>
            <Setter Property="PlaceholderColor" Value="#7F8C8D"/>
        </Style>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="15">

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="👤 Налогоплательщик" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <Entry Grid.Column="0" Text="{Binding NdflLastName}" Placeholder="Фамилия" />
                    <Entry Grid.Column="1" Text="{Binding NdflFirstName}" Placeholder="Имя" />
                    <Entry Grid.Column="2" Text="{Binding NdflPatronymic}" Placeholder="Отчество" />
                </Grid>
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Entry Grid.Column="0" Text="{Binding NdflInn}" Placeholder="ИНН (12 цифр)" Keyboard="Numeric" />
                    <Entry Grid.Column="1" Text="{Binding NdflPhone}" Placeholder="Телефон" Keyboard="Telephone" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="🏢 Инспекция и период" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <Entry Grid.Column="0" Text="{Binding NdflTaxCode}" Placeholder="Код ИФНС" Keyboard="Numeric" />
                    <Entry Grid.Column="1" Text="{Binding NdflOktmo}" Placeholder="ОКТМО" Keyboard="Numeric" />
                    <Entry Grid.Column="2" Text="{Binding NdflYear}" Placeholder="Год" Keyboard="Numeric" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="💼 Доход (Работодатель)" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Entry Text="{Binding NdflEmployerName}" Placeholder="Название (ООО Ромашка)" />
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Entry Grid.Column="0" Text="{Binding NdflEmployerInn}" Placeholder="ИНН орг." Keyboard="Numeric" />
                    <Entry Grid.Column="1" Text="{Binding NdflEmployerKpp}" Placeholder="КПП орг." Keyboard="Numeric" />
                </Grid>
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Entry Grid.Column="0" Text="{Binding NdflIncome}" Placeholder="Доход (₽)" Keyboard="Numeric" TextColor="#27AE60" FontAttributes="Bold"/>
                    <Entry Grid.Column="1" Text="{Binding NdflTaxWithheld}" Placeholder="Удерж. налог" Keyboard="Numeric" TextColor="#E74C3C"/>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="💰 Заявленные вычеты" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <Entry Grid.Column="0" Text="{Binding NdflEduExp}" Placeholder="Обучение" Keyboard="Numeric" />
                    <Entry Grid.Column="1" Text="{Binding NdflMedExp}" Placeholder="Лечение" Keyboard="Numeric" />
                    <Entry Grid.Column="2" Text="{Binding NdflFitExp}" Placeholder="Фитнес" Keyboard="Numeric" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#3498DB" StrokeThickness="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="💳 Возврат средств" FontAttributes="Bold" TextColor="#3498DB" FontSize="16" />
                <Entry Text="{Binding NdflRefundAmount}" Placeholder="Сумма к возврату (₽)" Keyboard="Numeric" FontAttributes="Bold" TextColor="#3498DB"/>
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Entry Grid.Column="0" Text="{Binding NdflBankBik}" Placeholder="БИК банка" Keyboard="Numeric" />
                    <Entry Grid.Column="1" Text="{Binding NdflBankAccount}" Placeholder="Номер счета" Keyboard="Numeric" />
                </Grid>
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ContentView>