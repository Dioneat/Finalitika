<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels"
             x:DataType="viewmodels:DocumentEditorViewModel"
             x:Class="Finalitika10.Views.DocumentForms.ClaimStatementFormView">

    <ContentView.Resources>
        <Style TargetType="Entry">
            <Setter Property="BackgroundColor" Value="#F8F9FA"/>
            <Setter Property="TextColor" Value="#2C3E50"/>
            <Setter Property="PlaceholderColor" Value="#7F8C8D"/>
        </Style>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="15">

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="🏛️ Суд" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Label Text="Название суда:" FontSize="12" TextColor="#7F8C8D"/>
                <Entry Text="{Binding CourtName}" Placeholder="Басманный районный суд" />
                <Label Text="Город:" FontSize="12" TextColor="#7F8C8D" Margin="0,5,0,0"/>
                <Entry Text="{Binding CourtCity}" Placeholder="г. Москва" />
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#3498DB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="👤 Истец (Вы)" FontAttributes="Bold" TextColor="#3498DB" FontSize="16" />
                <Entry Text="{Binding PlaintiffName}" Placeholder="ФИО Истца" />
                <Entry Text="{Binding PlaintiffAddress}" Placeholder="Адрес регистрации/проживания" />
                <Entry Text="{Binding PlaintiffPhone}" Placeholder="Контактный телефон" Keyboard="Telephone" />
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#E74C3C" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="👤 Ответчик (Должник)" FontAttributes="Bold" TextColor="#E74C3C" FontSize="16" />
                <Entry Text="{Binding DefendantName}" Placeholder="ФИО Ответчика" />
                <Entry Text="{Binding DefendantAddress}" Placeholder="Адрес регистрации/проживания" />
                <Entry Text="{Binding DefendantPhone}" Placeholder="Контактный телефон" Keyboard="Telephone" />
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="📜 Суть требований" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Дата договора:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding ClaimLoanDate}" Placeholder="22.03.2024" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Сумма долга:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding ClaimLoanAmount}" Placeholder="400 000" Keyboard="Numeric" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Должен вернуть до:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding ClaimReturnDate}" Placeholder="28.03.2025" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Дата подачи иска:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding ClaimDate}" Placeholder="05.04.2025" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ContentView>