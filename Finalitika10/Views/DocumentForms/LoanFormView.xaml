<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels"
             x:DataType="viewmodels:DocumentEditorViewModel"
             x:Class="Finalitika10.Views.DocumentForms.LoanFormView">

    <ContentView.Resources>
        <Style TargetType="Entry">
            <Setter Property="BackgroundColor" Value="#F8F9FA"/>
            <Setter Property="TextColor" Value="#2C3E50"/>
            <Setter Property="PlaceholderColor" Value="#7F8C8D"/>
        </Style>
        <Style TargetType="Editor">
            <Setter Property="BackgroundColor" Value="#F8F9FA"/>
            <Setter Property="TextColor" Value="#2C3E50"/>
            <Setter Property="PlaceholderColor" Value="#7F8C8D"/>
        </Style>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="15">

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="📅 Основные данные" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Город:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding City}" Placeholder="г. Москва" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Дата договора:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding AgreementDate}" Placeholder="22.03.2025" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="👥 Стороны" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Label Text="ФИО Заимодавца (дает деньги):" FontSize="12" TextColor="#7F8C8D"/>
                <Entry Text="{Binding LenderName}" Placeholder="Макеев Артем Олегович" />

                <Label Text="ФИО Заемщика (берет деньги):" FontSize="12" TextColor="#7F8C8D" Margin="0,10,0,0"/>
                <Entry Text="{Binding BorrowerName}" Placeholder="Мохов Валентин Викторович" />
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="💵 Условия займа" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Сумма займа:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding LoanAmount}" Placeholder="400 000" Keyboard="Numeric" FontAttributes="Bold" TextColor="#27AE60"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Пени за просрочку:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding PenaltyRate}" Placeholder="1%" />
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Дата передачи:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding TransferDate}" Placeholder="28.03.2025" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Дата возврата:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding ReturnDate}" Placeholder="28.03.2026" />
                    </VerticalStackLayout>
                </Grid>

                <Label Text="Способ передачи денег:" FontSize="12" TextColor="#7F8C8D" Margin="0,10,0,0"/>
                <Picker SelectedItem="{Binding TransferMethod}" BackgroundColor="#F8F9FA" Title="Выберите способ">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>наличными</x:String>
                            <x:String>безналичным переводом</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="📝 Реквизиты сторон" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Label Text="Заимодавец (Паспорт, Адрес, ИНН):" FontSize="12" TextColor="#7F8C8D"/>
                <Editor Text="{Binding LenderRequisites}" AutoSize="TextChanges" Placeholder="Вставьте реквизиты..." HeightRequest="80"/>

                <Label Text="Заемщик (Паспорт, Адрес, ИНН):" FontSize="12" TextColor="#7F8C8D" Margin="0,10,0,0"/>
                <Editor Text="{Binding BorrowerRequisites}" AutoSize="TextChanges" Placeholder="Вставьте реквизиты..." HeightRequest="80"/>
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ContentView>