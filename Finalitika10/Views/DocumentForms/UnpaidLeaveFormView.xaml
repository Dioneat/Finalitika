<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels"
             x:DataType="viewmodels:DocumentEditorViewModel"
             x:Class="Finalitika10.Views.DocumentForms.UnpaidLeaveFormView">

    <ContentView.Resources>
        <Style TargetType="Entry">
            <Setter Property="BackgroundColor" Value="#F8F9FA"/>
            <Setter Property="TextColor" Value="#2C3E50"/>
            <Setter Property="PlaceholderColor" Value="#7F8C8D"/>
        </Style>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="15">
        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="🏢 Стороны" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Entry Text="{Binding CompanyName}" Placeholder="Название компании (ООО Ромашка)" />
                <Entry Text="{Binding DirectorName}" Placeholder="ФИО Директора (в им. падеже)" />
                <Entry Text="{Binding EmployeeName}" Placeholder="ФИО Работника (в им. падеже)" />
            </VerticalStackLayout>
        </Border>

        <Border BackgroundColor="White" Padding="15" Stroke="#EBEBEB" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Label Text="⏳ Детали и причина" FontAttributes="Bold" TextColor="#2C3E50" FontSize="16" />
                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Дата начала:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding LeaveStartDate}" Placeholder="10.05.2025" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Кол-во дней:" FontSize="12" TextColor="#7F8C8D"/>
                        <Entry Text="{Binding LeaveDaysCount}" Placeholder="3" Keyboard="Numeric" />
                    </VerticalStackLayout>
                </Grid>

                <Label Text="Причина (в творительном падеже):" FontSize="12" TextColor="#7F8C8D" Margin="0,10,0,0"/>
                <Entry Text="{Binding LeaveReason}" Placeholder="по семейным обстоятельствам" />
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentView>