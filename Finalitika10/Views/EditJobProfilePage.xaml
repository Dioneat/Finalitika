<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels"
             x:DataType="viewmodels:EditJobProfileViewModel"
             x:Class="Finalitika10.Views.EditJobProfilePage"
             xmlns:controls="clr-namespace:Finalitika10.Views.JobForms"
             BackgroundColor="White"
             Title="Моя должность">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">
            <Border BackgroundColor="White" Padding="20" Stroke="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <controls:JobParametersForm />

            </Border>
            <Button Text="Сохранить профиль" Command="{Binding SaveCommand}" BackgroundColor="#27AE60" TextColor="White" CornerRadius="12" HeightRequest="50"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>