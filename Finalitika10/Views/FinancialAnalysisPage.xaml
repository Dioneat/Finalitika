<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Finalitika10.Models"
             xmlns:viewmodels="clr-namespace:Finalitika10.ViewModels.AnalysisViewModels"
             x:DataType="viewmodels:AnalysisViewModel"
             xmlns:micro="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="Finalitika10.FinancialAnalysisPage" BackgroundColor="#F6F6F6">

    <Grid>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="0,20,0,100">

                <Border Margin="20,0" Padding="20" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{Binding WeatherGradientStart}" Offset="0.0" />
                            <GradientStop Color="{Binding WeatherGradientEnd}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Индекс здоровья" FontSize="14" TextColor="#E0F7FA"/>
                                <HorizontalStackLayout Spacing="5" VerticalOptions="End">
                                    <Label Text="{Binding FinancialHealthScore}" FontSize="36" FontAttributes="Bold" TextColor="White"/>
                                    <Label Text="/ 100" FontSize="16" TextColor="#B2EBF2" VerticalOptions="End" Margin="0,0,0,8"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding WeatherIcon}" FontSize="48" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#40FFFFFF"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding WeatherTitle}" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="{Binding WeatherDescription}" FontSize="14" TextColor="#E0F7FA" LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*, *" Margin="0,10,0,0" ColumnSpacing="15">
                            <Border Grid.Column="0" BackgroundColor="#33000000" Padding="12" Stroke="Transparent">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout>
                                    <Label Text="Ожид. доход" FontSize="11" TextColor="#B2EBF2"/>
                                    <Label Text="{Binding ExpectedIncome, StringFormat='+{0:N0} ₽'}" FontSize="14" FontAttributes="Bold" TextColor="White"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="#33000000" Padding="12" Stroke="Transparent">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout>
                                    <Label Text="Ожид. расход" FontSize="11" TextColor="#B2EBF2"/>
                                    <Label Text="{Binding ExpectedExpenses, StringFormat='-{0:N0} ₽'}" FontSize="14" FontAttributes="Bold" TextColor="White"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <VerticalStackLayout Spacing="10" Padding="20,0">
                    <Label Text="Денежный поток" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                    <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="15">
                                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                    <BoxView Color="#27AE60" WidthRequest="12" HeightRequest="12" CornerRadius="6" VerticalOptions="Center"/>
                                    <Label Text="Доходы" FontSize="12" TextColor="#7F8C8D"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                    <BoxView Color="#E74C3C" WidthRequest="12" HeightRequest="12" CornerRadius="6" VerticalOptions="Center"/>
                                    <Label Text="Расходы" FontSize="12" TextColor="#7F8C8D"/>
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>

                            <micro:ChartView Chart="{Binding CashFlowChart}" HeightRequest="200" BackgroundColor="Transparent"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" Padding="20,0,20,20">
                    <Label Text="Структура расходов" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                    <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <micro:ChartView Chart="{Binding CategoriesChart}" HeightRequest="250" BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="10" Padding="20,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Скрытые траты" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding TotalHiddenAmount, StringFormat='-{0:N0} ₽/мес'}" FontSize="14" FontAttributes="Bold" TextColor="#7F8C8D" VerticalOptions="Center"/>
                    </Grid>

                    <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding HiddenExpenses}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:HiddenExpense">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Grid.Column="0" Text="{Binding Icon}" FontSize="24" VerticalOptions="Center" Margin="0,0,15,0"/>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50"/>
                                            <Label Text="{Binding Frequency}" FontSize="12" TextColor="{Binding StatusColor}"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding Amount, StringFormat='{0:N0} ₽'}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" Padding="20,10,20,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Анализ поведения" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="За месяц" FontSize="12" TextColor="#3498DB" VerticalOptions="Center"/>
                    </Grid>

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="-20,0">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding EmotionalPurchases}" Spacing="15" Padding="20,0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:EmotionalPurchase">
                                    <Border BackgroundColor="White" WidthRequest="220" Padding="15" Stroke="Transparent">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16"/>
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Opacity="0.05" Offset="0,4" Radius="8"/>
                                        </Border.Shadow>

                                        <VerticalStackLayout Spacing="10">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <Border Grid.Column="0" BackgroundColor="{Binding TagColor, StringFormat='{0}1A'}" Padding="8,4" Stroke="Transparent" HorizontalOptions="Start">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding Tag}" FontSize="10" FontAttributes="Bold" TextColor="{Binding TagColor}"/>
                                                </Border>
                                                <Label Grid.Column="1" Text="{Binding Icon}" FontSize="20"/>
                                            </Grid>

                                            <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" MaxLines="2" LineBreakMode="TailTruncation"/>

                                            <Grid ColumnDefinitions="*, Auto" Margin="0,5,0,0">
                                                <Label Grid.Column="0" Text="{Binding DateText}" FontSize="11" TextColor="#7F8C8D" VerticalOptions="End"/>
                                                <Label Grid.Column="1" Text="{Binding Amount, StringFormat='-{0:N0} ₽'}" FontSize="14" FontAttributes="Bold" TextColor="#E74C3C" VerticalOptions="End"/>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="15" Padding="20,10,20,10">

                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Налоговые вычеты" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                            <Label Text="Верните 13% от своих трат" FontSize="12" TextColor="#7F8C8D"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center">
                            <Label Text="К возврату" FontSize="10" TextColor="#7F8C8D" HorizontalOptions="End"/>
                            <Label Text="{Binding TotalPotentialRefund, StringFormat='+{0:N0} ₽'}" FontSize="18" FontAttributes="Bold" TextColor="#27AE60" HorizontalOptions="End"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Border BackgroundColor="White" Padding="15" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="15">

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding TaxDeductions}" Spacing="12">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:TaxDeductionOpportunity">
                                        <Grid ColumnDefinitions="Auto, *, Auto">

                                            <Border Grid.Column="0" BackgroundColor="#F4F6F8" WidthRequest="40" HeightRequest="40" Stroke="Transparent" Margin="0,0,12,0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Icon}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50"/>
                                                <Label Text="{Binding Description}" FontSize="11" TextColor="#7F8C8D" MaxLines="1" LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                                <Label Text="{Binding EligibleAmount, StringFormat='Траты: {0:N0} ₽'}" FontSize="10" TextColor="#7F8C8D" HorizontalOptions="End"/>
                                                <Label Text="{Binding PotentialRefund, StringFormat='+{0:N0} ₽'}" FontSize="14" FontAttributes="Bold" TextColor="#27AE60" HorizontalOptions="End"/>
                                            </VerticalStackLayout>

                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#F4F6F8"/>

                            <Button Text="Сформировать отчет 3-НДФЛ"
                                    Command="{Binding GenerateTaxReportCommand}"
                                    BackgroundColor="#2980B9"
                                    TextColor="White"
                                    CornerRadius="10"
                                    HeightRequest="48"
                                    FontAttributes="Bold"/>

                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="15" Padding="20,0">
                    <Label Text="Умные рекомендации" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Insights}" Spacing="15">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:FinancialInsight">
                                <Border BackgroundColor="{Binding BackgroundColor}" Padding="20" Stroke="Transparent">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="10">
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="{Binding Icon}" FontSize="24"/>
                                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="{Binding TextColor}" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Description}" FontSize="14" TextColor="#34495E" LineBreakMode="WordWrap"/>
                                        <Button Text="{Binding ActionText}" BackgroundColor="{Binding TextColor}" TextColor="White" CornerRadius="8" HeightRequest="36" Margin="0,10,0,0"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView BackgroundColor="Black" Opacity="0.6" IsVisible="{Binding IsFabMenuOpen}">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFabMenuCommand}"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <VerticalStackLayout HorizontalOptions="End" VerticalOptions="End" Margin="20" Spacing="15">

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Категория" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="📂" Command="{Binding AddCategoryCommand}" BackgroundColor="White" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Счет" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="💳" Command="{Binding AddAccountCommand}" BackgroundColor="White" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Перевод" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="🔄" Command="{Binding AddTransferCommand}" BackgroundColor="White" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Расход" FontAttributes="Bold" TextColor="#E74C3C"/>
                </Border>
                <Button Text="💸" Command="{Binding AddTransactionCommand}" CommandParameter="Expense" BackgroundColor="White" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Доход" FontAttributes="Bold" TextColor="#27AE60"/>
                </Border>
                <Button Text="💰" Command="{Binding AddTransactionCommand}" CommandParameter="Income" BackgroundColor="White" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" IsVisible="{Binding IsFabMenuOpen}">
                <Border BackgroundColor="White" Padding="12,6" Stroke="Transparent" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Импорт выписки" FontAttributes="Bold" TextColor="#2C3E50"/>
                </Border>
                <Button Text="📥" Command="{Binding OpenImportCommand}" BackgroundColor="White" FontSize="20" CornerRadius="24" HeightRequest="48" WidthRequest="48">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,2" Radius="5"/>
                    </Button.Shadow>
                </Button>
            </HorizontalStackLayout>
            <Button Text="{Binding FabIcon}" Command="{Binding ToggleFabMenuCommand}" FontAttributes="Bold" FontSize="28" TextColor="White" BackgroundColor="#2980B9" CornerRadius="28" HeightRequest="56" WidthRequest="56" HorizontalOptions="End" Margin="0,5,0,0">
                <Button.Shadow>
                    <Shadow Brush="Black" Opacity="0.3" Offset="0,4" Radius="8"/>
                </Button.Shadow>
            </Button>

        </VerticalStackLayout>
    </Grid>

</ContentPage>